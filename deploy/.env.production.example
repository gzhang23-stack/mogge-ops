APP_NAME=募格双公众号 AI 内容运营系统

# Frontend origin. Use your Vercel domain or your own domain.
FRONTEND_ORIGIN=https://your-frontend.vercel.app

# Production database.
# Supabase example:
# DATABASE_URL=postgresql+psycopg://postgres.xxxxx:YOUR_PASSWORD@aws-0-ap-southeast-1.pooler.supabase.com:6543/postgres?sslmode=require
#
# TencentDB for PostgreSQL example:
# DATABASE_URL=postgresql+psycopg://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require
#
# Emergency single-server fallback:
# DATABASE_URL=sqlite:////app/data/mogge_ops.db
DATABASE_URL=

# OpenAI-compatible LLM gateway.
LLM_BASE_URL=https://api.deepseek.com
LLM_API_KEY=
LLM_MODEL=deepseek-v4-pro

# WeChat official account credentials.
WECHAT_ACADEMIC_APP_ID=
WECHAT_ACADEMIC_APP_SECRET=
WECHAT_RECRUIT_APP_ID=
WECHAT_RECRUIT_APP_SECRET=

# DingTalk custom robot.
DINGTALK_WEBHOOK=
DINGTALK_SECRET=

# 365-day monitor scheduler.
MONITOR_AUTO_RUN_ENABLED=true
MONITOR_AUTO_RUN_INTERVAL_MINUTES=60
MONITOR_PUSH_TOPIC_LIMIT=8
MONITOR_PUSH_SCORE_THRESHOLD=0.68

# Optional RSSHub/WeWe-RSS base URL for WeChat account monitoring.
RSSHUB_BASE_URL=
