APP_NAME=募格双公众号 AI 内容运营系统
DATABASE_URL=sqlite:///./mogge_ops.db
FRONTEND_ORIGIN=http://localhost:3000

# OpenAI-compatible LLM gateway. Leave empty to use deterministic local fallback.
# DeepSeek example:
# LLM_BASE_URL=https://api.deepseek.com
# LLM_MODEL=deepseek-v4-pro
LLM_BASE_URL=
LLM_API_KEY=
LLM_MODEL=

# WeChat official account draft integration.
WECHAT_ACADEMIC_APP_ID=
WECHAT_ACADEMIC_APP_SECRET=
WECHAT_RECRUIT_APP_ID=
WECHAT_RECRUIT_APP_SECRET=

# DingTalk custom robot. Leave empty to disable push.
DINGTALK_WEBHOOK=
DINGTALK_SECRET=
MONITOR_AUTO_RUN_ENABLED=false
MONITOR_AUTO_RUN_INTERVAL_MINUTES=60
MONITOR_PUSH_TOPIC_LIMIT=8
MONITOR_PUSH_SCORE_THRESHOLD=0.68
RSSHUB_BASE_URL=
